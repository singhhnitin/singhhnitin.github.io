---
/**
 * This used to render its own <html><head><body>, nested inside the
 * <html> that default.astro / post.astro already own. Two <html>/<body>
 * elements on one page is invalid markup and is what was causing the
 * page content to appear to render twice. This is now a plain wrapper —
 * the real <html>/<body> live one level up.
 */
---
<div class="canvas">
    <div class="canvas__field" aria-hidden="true"></div>
    <div class="panel">
        <slot />
    </div>
</div>
<style>
    .canvas {
        @apply relative min-h-screen w-full overflow-x-clip;
        background: var(--bg);
    }
    /* Faint node/edge field on the wide margins either side of the panel —
       a nod to the knowledge graphs this blog is actually about, rather
       than an empty void. Pure decoration, stays out of the reading column. */
    .canvas__field {
        @apply pointer-events-none absolute inset-0;
        background-image:
            radial-gradient(circle at 1px 1px, var(--accent) 1.5px, transparent 0);
        background-size: 32px 32px;
        -webkit-mask-image: radial-gradient(ellipse 55% 60% at 50% 15%, transparent 45%, black 100%);
        mask-image: radial-gradient(ellipse 55% 60% at 50% 15%, transparent 45%, black 100%);
        opacity: 0.16;
    }
    .panel {
        @apply relative mx-auto w-full;
        max-width: 1040px;
        padding: 0 1.25rem;
    }
</style>
