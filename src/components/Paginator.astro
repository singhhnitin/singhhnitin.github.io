---
const { page } = Astro.props
---
<div class="page__actions">
    {page.url.prev && <a class="action__go-to-x" href={page.url.prev} title="Go to Previous">&larr; Prev</a>}
    {page.url.next && <a class="action__go-to-x" href={page.url.next} title="Go to Next">Next &rarr;</a>}
</div>
<style>
    .page__actions {
        @apply flex justify-center md:justify-end py-6 gap-4
    }
    .action__go-to-x {
        @apply text-sm uppercase tracking-wide hover:underline;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        color: var(--text-muted);
    }
    .action__go-to-x:hover {
        color: var(--accent);
    }
</style>
