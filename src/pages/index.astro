---
export const prerender = true
import { getCollection } from 'astro:content'
import DefaultPageLayout from '$/layouts/default.astro'
import PostPreviewList from '$/components/PostPreviewList.astro'
import Prose from '$/components/Prose.astro'
const title = 'Home'
const description = 'GSoC 2026 contributor at DBpedia Hindi Chapter'
const posts = await getCollection('blog')
---
<DefaultPageLayout content={{ title, description }} showPageHeader={false}>
    <div class="hero">
        <div class="badges">
            <img src="/gsoc.png" alt="Google Summer of Code" class="badge-logo" />
            <span class="badge-x">×</span>
            <img src="/dbpedia.png" alt="DBpedia" class="badge-logo" />
        </div>
        <div class="hero__says">
            <Prose>
                <h2>Hey, I'm Nitin 👋</h2>
                <p>
                    I'm a third year CS student from Mau, Uttar Pradesh, currently contributing to 
                    <strong>DBpedia</strong> as a <strong>GSoC 2026</strong> developer. 
                    I write here about what I'm building, breaking, and learning along the way — 
                    mostly Hindi NLP, knowledge graphs, and open source.
                </p>
                <p>
                    This summer I'm working on fine-tuning small language models for Hindi relational 
                    triple extraction and building a human-in-the-loop feedback interface for the 
                    DBpedia Hindi Chapter.
                </p>
            </Prose>
        </div>
    </div>
    <hr/>
    <PostPreviewList posts={posts.slice(0, 3)} heading="recent posts"/>
    <div class="page__actions">
        <a class="action__go-to-blog ink-h" href="/blog" title="All Posts">All Posts &rarr;</a>
    </div>
</DefaultPageLayout>
<style>
    .hero {
        @apply flex flex-col gap-6 w-full transition-all pb-4
    }
    .badges {
        @apply flex flex-row items-center gap-4 justify-center md:justify-start py-2
    }
    .badge-logo {
        @apply h-12 w-auto object-contain
    }
    .badge-x {
        @apply text-2xl text-gray-400 font-light
    }
    .hero__says {
        @apply flex-1 text-center md:text-left
    }
    .page__actions {
        @apply flex justify-center md:justify-end py-6
    }
    .action__go-to-blog {
        @apply py-4 hover:underline
    }
</style>
